# ─────────────────────────────────────────────────────────────
# aonikenk-proposals — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# Set these in Vercel → Project Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Default code — applies to any proposal that doesn't have its own
PROPOSAL_CODE_DEFAULT=your-default-code-here

# Per-proposal codes (slug = page filename, uppercased, hyphens → underscores)
# /proposals/af-servicios-mineros → PROPOSAL_CODE_AF_SERVICIOS_MINEROS
PROPOSAL_CODE_AF_SERVICIOS_MINEROS=your-code-for-af-here

# Add more as you create proposals:
# PROPOSAL_CODE_NEW_CLIENT=another-code-here
