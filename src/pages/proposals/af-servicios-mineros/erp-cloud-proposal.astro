---
import ProposalLayout     from '../../../layouts/ProposalLayout.astro';
import ProposalNav        from '../../../components/ProposalNav.astro';
import ProposalCover      from '../../../components/ProposalCover.astro';
import ProposalModule     from '../../../components/ProposalModule.astro';
import ProposalTotals     from '../../../components/ProposalTotals.astro';
import ProposalConditions from '../../../components/ProposalConditions.astro';
import ProposalSignatures from '../../../components/ProposalSignatures.astro';
import ProposalFooter     from '../../../components/ProposalFooter.astro';

// ── Data ──────────────────────────────────────────────────────
import data from '../../../data/clients/af-servicios-mineros/erp-cloud-proposal.json';

// ── Auth guard ────────────────────────────────────────────────
const COOKIE_NAME = 'aonikenk_auth';
const slug        = 'AF_SERVICIOS_MINEROS_ERP_CLOUD_PROPOSAL';
const validCode   = process.env[`PROPOSAL_CODE_${slug}`]
                 ?? process.env.PROPOSAL_CODE_DEFAULT;
const cookie      = Astro.cookies.get(COOKIE_NAME);

if (!cookie || !validCode || cookie.value !== validCode) {
  return Astro.redirect(`/login?redirect=${Astro.url.pathname}`, 302);
}
// ─────────────────────────────────────────────────────────────

interface Item {
  name: string;
  desc: string;
  qty: string;
  price: number;
  show: boolean;
  exclude_from_subtotal?: boolean;
  exclude_from_total?: boolean;
}

const { meta, provider, client, intro, context, modules, totals, conditions } = data;

const pageTitle       = `Presupuesto #${meta.ref} — ${client.name} · ${provider.name}${provider.tld}`;
const pageDescription = `Propuesta de ${meta.proposal_desc} para ${client.name}, preparada por ${provider.name}${provider.tld}.`;

let subTotal = 0;
let subTotalWithExtras = 0;
const totals_aux: {
    modules: { 
      num: string;
      title: string;
      desc: string;
      table_title: string;
      items: Item[];
      subtotal_label: string;
      currency: string;
      subtotal: number;
      subtotal_first_month: number;
      subtotal_label_first_month?: string;
      notes?: string[];
    }[];
  subtotal: { label: string; value: number };
  extras: { label: string; value: number };
  clientBenefits: { label: string; value: number; }[];
  subscriptionPlans: { label: string; description: string; value: number; }[];
  subscriptionPlansNotes?: string[];
  discount: { label: string; percent: number };
  total: { label: string; value: number };
  notes?: string[];
} = {
  modules: [],
  subtotal: { label: totals.subtotal.label, value: 0 },
  extras: { label: totals.extras.label, value: totals.extras.value },
  clientBenefits: totals.clientBenefits,
  subscriptionPlans: totals.subscriptionPlans,
  subscriptionPlansNotes: totals.subscriptionPlansNotes,
  discount: totals.discount,
  total:  totals.total,
  notes: totals.notes || [],
};

modules.map(mod => {
            const subTotalModule = mod.items.filter(item => item.show && !(item.exclude_from_subtotal || item.exclude_from_total)).reduce((acc, item) => acc + (item.price * parseInt(item.qty)), 0);
            const subTotalFirstMonthModule = mod.items.filter(item => item.show && !item.exclude_from_total).reduce((acc, item) => acc + (item.price * parseInt(item.qty)), 0);
            subTotal += subTotalModule;   
            subTotalWithExtras += subTotalFirstMonthModule;         
            totals_aux.modules = [...totals_aux.modules, {
              num: mod.num,
              title: mod.title,
              table_title: mod.table_title,
              desc: mod.desc,
              items: mod.items,
              subtotal_label: mod.subtotal_label,
              subtotal_label_first_month: mod.subtotal_label_first_month,
              currency: meta.currency,
              subtotal: subTotalModule,
              subtotal_first_month: subTotalFirstMonthModule,
              notes: mod.notes
            }]
  });
---

<ProposalLayout title={pageTitle} description={pageDescription}>

  <ProposalNav
    name={provider.name}
    tld={provider.tld}
    ref={meta.ref}
    date={meta.date}
  />

  <ProposalCover
    provider={provider}
    client={client}
    meta={meta}
    totalValue={(subTotalWithExtras * (1 - totals_aux.discount.percent / 100)).toFixed(2)}
  />

  <div id="content">
    <div class="p-inner">

      <!-- Intro -->
      <div class="s-header reveal">
        <div class="s-eyebrow"><span>Introducción</span></div>
        <h2 class="s-title">Contexto del proyecto</h2>
        <p class="s-desc">{intro}</p>
      </div>
      <div class="rule"></div>

      <!-- Contexto competitivo -->
      <!-- <div class="s-header reveal">
        <div class="s-eyebrow"><span>Análisis de mercado</span></div>
        <h2 class="s-title">{context.title}</h2>
        <p class="s-desc">{context.body}</p>
      </div> -->

      <!-- Competitor comparison table -->
      <!-- <table class="srv-table reveal" style="margin-bottom:40px">
        <tr class="t-head-section"><td colspan="4">COMPARATIVA DE SOLUCIONES ERP — MERCADO ARGENTINO</td></tr>
        <tr class="t-head-cols">
          <th>Solución</th><th>Modelo</th><th>Módulos clave</th><th>Observación</th>
        </tr>
        <tbody>
          <tr>
            <td>Holistor Gestión ERP</td>
            <td>SaaS · Cloud</td>
            <td>Ventas, Compras, Stock, Tesorería, Contabilidad</td>
            <td>Sin módulo RRHH. No adaptado al sector minero.</td>
          </tr>
          <tr>
            <td>Finnegans GO</td>
            <td>SaaS · Enterprise</td>
            <td>ERP completo + CRM + HCM (Quippos)</td>
            <td>Orientado a empresas medianas/grandes. Sin precio publicado. Implementación consultiva larga.</td>
          </tr>
          <tr>
            <td>Tango Software</td>
            <td>On-premise</td>
            <td>ERP completo, RRHH, contabilidad avanzada</td>
            <td>No cloud nativo. Requiere infraestructura propia. Desde ~$600.000 ARS/mes.</td>
          </tr>
          <tr>
            <td style="color:var(--sienna);font-weight:700">aonikenk.dev (propuesta)</td>
            <td>SaaS · Cloud · A medida</td>
            <td>Facturación, Finanzas, Stock, RRHH, Accesos — adaptados al sector minero</td>
            <td style="color:var(--sienna)">Desarrollo a medida. Arquitectura multi-tenant reutilizable. Stack moderno.</td>
          </tr>
        </tbody>
      </table>
      <div class="rule"></div> -->

      <!-- Modules -->
      {totals_aux.modules.map(mod => (
        <ProposalModule
            num={mod.num}
            title={mod.title}
            desc={mod.desc}
            table_title={mod.table_title}
            items={mod.items}
            currency={meta.currency}
            subtotal={mod.subtotal}
            subtotal_first_month={mod.subtotal_first_month}
            subtotal_label={mod.subtotal_label}
            subtotal_label_first_month={mod.subtotal_label_first_month}
            notes={mod.notes}
        />
      ))}

      <!-- Totals -->
      <ProposalTotals 
          totals={
          {
            ...totals_aux, 
            extras: { label: totals_aux.extras.label, value: (subTotalWithExtras - subTotal) }, 
            clientBenefits: totals_aux.clientBenefits,
            subscriptionPlans: totals_aux.subscriptionPlans,
            subscriptionPlansNotes: totals_aux.subscriptionPlansNotes,
            subtotal: { label: totals_aux.subtotal.label, value: subTotal }, 
            total: { label: totals_aux.total.label, value: (subTotalWithExtras * (1 - totals_aux.discount.percent / 100)) }
          }} 
          currency={meta.currency}/>
      <ProposalConditions conditions={conditions} />
      <ProposalSignatures provider={provider} client={client} />

    </div>
  </div>

  <ProposalFooter provider={provider} client={client} meta={meta} />

</ProposalLayout>

<style lang="scss">
  @use '../../../styles/tokens' as *;
  #content { padding: 0 0 100px; background: var(--obsidian); }
</style>