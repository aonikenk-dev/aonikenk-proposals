---
import ProposalLayout from '../../../layouts/ProposalLayout.astro';
import ProposalNav from '../../../components/ProposalNav.astro';
import ProposalCover from '../../../components/ProposalCover.astro';
import ProposalModule from '../../../components/ProposalModule.astro';
import ProposalTotals from '../../../components/ProposalTotals.astro';
import ProposalConditions from '../../../components/ProposalConditions.astro';
import ProposalSignatures from '../../../components/ProposalSignatures.astro';
import ProposalFooter from '../../../components/ProposalFooter.astro';

// ── Data ──────────────────────────────────────────────────────
import data from '../../../data/clients/netdriver/tgrs-migration-proposal.json';

// ── Auth guard ────────────────────────────────────────────────
const COOKIE_NAME = 'aonikenk_auth';
const slug = 'NETDRIVER_TGRS_MIGRATION_PROPOSAL';
const validCode   = process.env[`PROPOSAL_CODE_${slug}`]
                 ?? process.env.PROPOSAL_CODE_DEFAULT;
// const validCode =
//   import.meta.env[`PROPOSAL_CODE_${slug}`] ??
//   import.meta.env.PROPOSAL_CODE_DEFAULT;
const cookie = Astro.cookies.get(COOKIE_NAME);

if (!cookie || !validCode || cookie.value !== validCode) {
  return Astro.redirect(`/login?redirect=${Astro.url.pathname}`, 302);
}
// ─────────────────────────────────────────────────────────────

interface Item {
  name: string;
  desc: string;
  qty: string;
  price: number;
  show: boolean;
  exclude_from_subtotal?: boolean;
  exclude_from_total?: boolean;
}

const { meta, provider, client, intro, modules, totals, conditions } = data;

const pageTitle = `Presupuesto #${meta.ref} — ${client.name} · ${provider.name}${provider.tld}`;
const pageDescription = `Propuesta de ${meta.proposal_desc} para ${client.name}, preparada por ${provider.name}${provider.tld}.`;

let subTotal = 0;
let subTotalWithExtras = 0;
const totals_aux: {
  modules: {
    num: string;
    title: string;
    desc: string;
    table_title: string;
    items: Item[];
    subtotal_label: string;
    currency: string;
    subtotal: number;
    subtotal_first_month: number;
    subtotal_label_first_month?: string;
    notes?: string[];
  }[];
  subtotal: { label: string; value: number };
  extras: { label: string; value: number };
  clientBenefits: { label: string; value: number }[];
  subscriptionPlans: { label: string; description: string; value: number }[];
  subscriptionPlansNotes?: string[];
  discount: { label: string; percent: number };
  total: { label: string; value: number };
  notes?: string[];
} = {
  modules: [],
  subtotal: { label: totals.subtotal.label, value: 0 },
  extras: { label: totals.extras.label, value: totals.extras.value },
  clientBenefits: totals.clientBenefits,
  subscriptionPlans: totals.subscriptionPlans,
  subscriptionPlansNotes: totals.subscriptionPlansNotes,
  discount: totals.discount,
  total: totals.total,
  notes: totals.notes || [],
};

modules.map((mod) => {
  const subTotalModule = mod.items
    .filter(
      (item) =>
        item.show && !(item.exclude_from_subtotal || item.exclude_from_total),
    )
    .reduce((acc, item) => acc + item.price * parseInt(item.qty), 0);
  const subTotalFirstMonthModule = mod.items
    .filter((item) => item.show && !item.exclude_from_total)
    .reduce((acc, item) => acc + item.price * parseInt(item.qty), 0);
  subTotal += subTotalModule;
  subTotalWithExtras += subTotalFirstMonthModule;
  totals_aux.modules = [
    ...totals_aux.modules,
    {
      num: mod.num,
      title: mod.title,
      table_title: mod.table_title,
      desc: mod.desc,
      items: mod.items,
      subtotal_label: mod.subtotal_label,
      subtotal_label_first_month: mod.subtotal_label_first_month,
      currency: meta.currency,
      subtotal: subTotalModule,
      subtotal_first_month: subTotalFirstMonthModule,
      notes: mod.notes,
    },
  ];
});
---

<ProposalLayout title={pageTitle} description={pageDescription}>
  <ProposalNav
    name={provider.name}
    tld={provider.tld}
    ref={meta.ref}
    date={meta.date}
  />

  <ProposalCover
    provider={provider}
    client={client}
    meta={meta}
    totalValue={(
      subTotalWithExtras *
      (1 - totals_aux.discount.percent / 100)
    ).toFixed(2)}
  />

  <div id="content">
    <div class="p-inner">
      <!-- Intro -->
      <div class="s-header reveal">
        <div class="s-eyebrow"><span>Introducción</span></div>
        <h2 class="s-title">Contexto del proyecto</h2>
        <p class="s-desc">{intro}</p>
      </div>
      <div class="rule"></div>

      <!-- Plan and Estimation -->

      <div class="s-header reveal">
        <div class="s-eyebrow"><span>Plan y Estimación</span></div>
        <h2 class="s-title">Plan y Estimación</h2>
        <p class="s-desc">A continuación se presenta el plan detallado y las estimaciones para la migración del sistema actual a la nueva arquitectura. 
          Se muestra el análisis del stack actual, los puntos críticos a considerar, el código que se conservará y las implicaciones técnicas. </p>
      </div>

      <!-- ══ 01 SISTEMA ACTUAL ══ -->
      <div class="s-header reveal">
        <div class="s-eyebrow"><span>01 — Sistema Actual</span></div>
        <h2 class="s-title">Stack Legacy (a reemplazar)</h2>
        <p class="s-desc">
          El sistema actual tiene dos capas de backend acopladas: ASP/VBScript
          construye el XML a partir de SQL Server y lo envía via HTTP POST a un
          PHP que sanitiza y llama al WS de TRGS. Los nodos marcados en Sienna
          se eliminan; el WS externo se conserva sin cambios.
        </p>
      </div>

        <div class="flow-row">
          <div class="flow-node dead">
            <div class="dead-badge">✕</div>
            <div class="fn-tag">Entrada</div>
            <div class="fn-name">Excel / Form</div>
            <div class="fn-tech">proceso manual</div>
          </div>
          <div class="flow-arrow">
            <div class="arrow-line"></div>
            <div class="arrow-label">HTTP POST XML</div>
          </div>
          <div class="flow-node dead">
            <div class="dead-badge">✕</div>
            <div class="fn-tag">Backend 1</div>
            <div class="fn-name">ASP / VBScript</div>
            <div class="fn-tech">SQL Server → XML</div>
          </div>
          <div class="flow-arrow">
            <div class="arrow-line"></div>
            <div class="arrow-label">POST input=XML</div>
          </div>
          <div class="flow-node dead">
            <div class="dead-badge">✕</div>
            <div class="fn-tag">Backend 2</div>
            <div class="fn-name">PHP</div>
            <div class="fn-tech">sanitize + SOAP</div>
          </div>
          <div class="flow-arrow">
            <div class="arrow-line"></div>
            <div class="arrow-label">SOAP 1.1</div>
          </div>
          <div class="flow-node ext">
            <div class="keep-badge">✓</div>
            <div class="fn-tag">Externo · intacto</div>
            <div class="fn-name">TRGS WS</div>
            <div class="fn-tech">trgs.com.ar</div>
          </div>
        </div>

        <div
          style="display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:3px;margin-bottom:30px;"
        >
          <div
            style="background:var(--carbon);padding:22px 24px;border-top:2px solid var(--sienna)"
          >
            <div
              style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--sienna);margin-bottom:10px"
            >
              Se elimina
            </div>
            <div style="font-size:11px;color:var(--muted);line-height:2">
              ASP / VBScript (IIS)<br />PHP (apache)<br />SQL Server (origen)<br
              />Comunicación XML cruda<br />Acoplamiento ASP↔PHP
            </div>
          </div>
          <div
            style="background:var(--carbon);padding:22px 24px;border-top:2px solid var(--moss)"
          >
            <div
              style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--moss);margin-bottom:10px"
            >
              Se conserva
            </div>
            <div style="font-size:11px;color:var(--muted);line-height:2">
              WS TRGS (trgs.com.ar)<br />Protocolo SOAP 1.1<br />Flujo eco →
              sesión → tramite<br />Credenciales de acceso<br />Lógica de
              negocio TRGS
            </div>
          </div>
          <div
            style="background:var(--carbon);padding:22px 24px;border-top:2px solid var(--ice)"
          >
            <div
              style="font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--ice);margin-bottom:10px"
            >
              Se migra
            </div>
            <div style="font-size:11px;color:var(--muted);line-height:2">
              filterOperatorErrors() → JS<br />changeCedulaAzulArray() → JS<br/>Frontend → React<br />Parser
              XML → JSON nativo
            </div>
          </div>
        </div>

      <div class="rule"></div>

      <!-- ══ 02 NUEVO SISTEMA ══ -->
      <div class="s-header reveal">
        <div class="s-eyebrow"><span>02 — Nueva Arquitectura</span></div>
        <h2 class="s-title">Stack Propuesto</h2>
        <p class="s-desc">
          Se propone una nueva arquitectura desacoplada con un backend Node.js
          que expone una API REST para que la consuma el frontend React, y maneja la
          integración con el WS de TRGS. El nuevo sistema procesa archivos Excel
          de forma nativa, transformando los datos a JSON y comunicándose con
          el WS de TRGS mediante SOAP. La migración se realizará en paralelo al
          sistema actual, asegurando la continuidad operativa. El WS de TRGS sigue siendo el destino final; solo cambia quién lo llama.
        </p>
      </div>

      <div class="arch-grid">

    <!-- REACT -->
    <div class="arch-layer react-layer">
      <div class="layer-tag">Frontend</div>
      <div class="layer-name c-react">React.js + Vite</div>
      <div class="layer-items">
        <div class="layer-item">FormDatosDelTramite<div class="li-sub">tipo, año, modo adquisición, etc.</div></div>
        <div class="layer-item">FormTitulares<div class="li-sub">titular principal + condominos</div></div>
        <div class="layer-item">FormVehiculo<div class="li-sub">certificado, chasis</div></div>
        <div class="layer-item">FormCedulasAzul<div class="li-sub">array dinámico</div></div>
        <div class="layer-item">FormApoderados<div class="li-sub">DJ apoderados</div></div>
        <div class="layer-item">FormGuardaHabitual</div>
        <div class="layer-item">ExcelUpload<div class="li-sub">SheetJS → pre-carga formularios</div></div>
        <div class="layer-item">Dashboard<div class="li-sub">historial, traID, PDFs</div></div>
      </div>
    </div>

    <!-- ARROW -->
    <div class="arch-connector">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#C0623A" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>

    <!-- NODE -->
    <div class="arch-layer node-layer">
      <div class="layer-tag">Backend</div>
      <div class="layer-name c-node">Node.js + Express</div>
      <div class="layer-items">
        <div class="layer-item">POST /api/tramites<div class="li-sub">recibe JSON, sanitiza, llama TRGS</div></div>
        <div class="layer-item">GET /api/tramites/:id/formulario<div class="li-sub">obtener_formularios → PDF</div></div>
        <div class="layer-item">POST /api/tramites/:id/cancelar<div class="li-sub">cancelar_tramite_01</div></div>
        <div class="layer-item">sanitize.js<div class="li-sub">filterOperatorErrors migrado a JS</div></div>
        <div class="layer-item">trgsService.js<div class="li-sub">eco → abrir_sesion → op → cerrar</div></div>
        <div class="layer-item">excelParser.js<div class="li-sub">SheetJS → objeto tramite</div></div>
      </div>
    </div>

    <!-- ARROW -->
    <div class="arch-connector">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#C0623A" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>

    <!-- DB -->
    <div class="arch-layer db-layer">
      <div class="layer-tag">Persistencia</div>
      <div class="layer-name c-db">SQL Server</div>
      <div class="layer-items">
        <div class="layer-item">tramites<div class="li-sub">estado, traID, timestamps</div></div>
        <div class="layer-item">titulares<div class="li-sub">FK → tramites</div></div>
        <div class="layer-item">apoderados<div class="li-sub">FK → tramites</div></div>
        <div class="layer-item">cedulas_azul<div class="li-sub">FK → tramites</div></div>
        <div class="layer-item">vehiculos<div class="li-sub">FK → tramites</div></div>
      </div>
    </div>

    <!-- ARROW -->
    <div class="arch-connector">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
        <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="#C0623A" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </div>

    <!-- TRGS -->
    <div class="arch-layer ext-layer">
      <div class="layer-tag">Externo · sin cambios</div>
      <div class="layer-name c-ext">TRGS Web Service</div>
      <div class="layer-items">
        <div class="layer-item">eco()<div class="li-sub">verificar disponibilidad</div></div>
        <div class="layer-item">abrir_sesion()<div class="li-sub">retorna ingID</div></div>
        <div class="layer-item">generar_tramite_01()<div class="li-sub">retorna traID</div></div>
        <div class="layer-item">obtener_formularios()<div class="li-sub">PDF base64</div></div>
        <div class="layer-item">cancelar_tramite_01()</div>
        <div class="layer-item">cerrar_sesion()</div>
      </div>
    </div>

      </div>

      <div class="rule"></div>

      <!-- ══ 03 DATA FLOW ══ -->
      <div class="s-header reveal">
        <div class="s-eyebrow"><span>03 — Flujo de Datos</span></div>
        <h2 class="s-title">Paso a paso</h2>
        <p class="s-desc">
          Recorrido completo de un trámite desde que el usuario carga el Excel hasta que recibe el traID confirmado y descarga el PDF.
        </p>
      </div>

      <div class="dataflow">
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">01</div>
        <div class="df-actor" style="color:#61dafb">React</div>
      </div>
      <div class="df-right">
        <div class="df-action">Usuario carga Excel o completa formulario web</div>
        <div class="df-detail">SheetJS parsea .xlsx → objeto JS con datosDelTramite, datosTitulares, datosVehiculo, etc.</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">02</div>
        <div class="df-actor" style="color:#61dafb">React</div>
      </div>
      <div class="df-right">
        <div class="df-action">Validación en el frontend antes de enviar</div>
        <div class="df-detail">CUIT, DNI, email, CP requeridos · preview de los datos · confirmación del operador</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">03</div>
        <div class="df-actor" style="color:var(--moss)">Node.js</div>
      </div>
      <div class="df-right">
        <div class="df-action">POST /api/tramites — guarda en DB con estado "pendiente"</div>
        <div class="df-detail">INSERT tramites + titulares + vehiculo + apoderados + cedulas</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">04</div>
        <div class="df-actor" style="color:var(--moss)">Node.js</div>
      </div>
      <div class="df-right">
        <div class="df-action">sanitize.js — limpia y normaliza todos los campos</div>
        <div class="df-detail">tel → solo números · CUIT/doc → parseFloat · email → trim/sin acentos · ocupación → solo letras · CP → solo números</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">05</div>
        <div class="df-actor" style="color:var(--moss)">Node.js</div>
      </div>
      <div class="df-right">
        <div class="df-action">trgsService.js — eco() → abrir_sesion() → generar_tramite_01()</div>
        <div class="df-detail">node-soap · SOAP 1.1 · https://www.trgs.com.ar:443/service/index.php?wsdl</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">06</div>
        <div class="df-actor" style="color:var(--sienna)">TRGS WS</div>
      </div>
      <div class="df-right">
        <div class="df-action">TRGS procesa el trámite y devuelve traID</div>
        <div class="df-detail">rspID = 1 → éxito · rspID &lt; 0 → error con rspDescrip legible</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">07</div>
        <div class="df-actor" style="color:var(--moss)">Node.js</div>
      </div>
      <div class="df-right">
        <div class="df-action">Guarda traID, actualiza estado → "completado" · cerrar_sesion()</div>
        <div class="df-detail">UPDATE tramites SET traID = ?, estado = 'completado' WHERE id = ?</div>
      </div>
    </div>
    <div class="df-step">
      <div class="df-left">
        <div class="df-step-num">08</div>
        <div class="df-actor" style="color:#61dafb">React</div>
      </div>
      <div class="df-right">
        <div class="df-action">Dashboard muestra traID confirmado + descarga PDF</div>
        <div class="df-detail">GET /api/tramites/:id/formulario?tipo=F01 | F12 → PDF base64 → descarga</div>
      </div>
    </div>
      </div>
      
      <div class="rule"></div>

      <!-- ══ 04 ESTIMACIÓN ══ -->
      <div class="s-header reveal">
        <div class="s-eyebrow"><span>04 — Estimación</span></div>
        <h2 class="s-title">Horas por Módulo</h2>
        <p class="s-desc">
          Desglose por área con las tareas concretas identificadas a partir del análisis del código existente (ASP, PHP, XMLs de prueba y manual del WS).
        </p>
      </div>

<div class="est-grid">

    <!-- BACKEND -->
    <div class="est-card">
      <div class="est-header">
        <div class="est-header-title">Backend — Node.js + Express</div>
        <div class="est-header-color" style="background:var(--moss)"></div>
      </div>
      <div class="est-rows">
        <div class="est-row">
          <div class="est-task">Setup proyecto, estructura, configuración<span class="task-sub">Express, cors, logger, estructura de carpetas</span></div>
          <div class="est-hours" style="color:var(--moss)">2 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">Modelos DB + migraciones (Sequelize/Prisma)<span class="task-sub">tramites, titulares, vehiculos, apoderados, cedulas</span></div>
          <div class="est-hours" style="color:var(--moss)">4 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">trgsService.js — cliente SOAP completo<span class="task-sub">eco, abrir_sesion, generar, obtener_formularios, cancelar, cerrar</span></div>
          <div class="est-hours" style="color:var(--moss)">8 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">sanitize.js — migración de filterOperatorErrors<span class="task-sub">todas las reglas del PHP + casos edge identificados</span></div>
          <div class="est-hours" style="color:var(--moss)">6 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">API routes: POST /tramites, GET /formulario, POST /cancelar<span class="task-sub">validación, manejo de errores TRGS, respuestas legibles</span></div>
          <div class="est-hours" style="color:var(--moss)">8 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">excelParser.js — mapeo columnas → objeto tramite<span class="task-sub">SheetJS, múltiples secciones, validación de columnas</span></div>
          <div class="est-hours" style="color:var(--moss)">8 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">Testing — servicios críticos (Jest)<span class="task-sub">sanitize unit tests, SOAP mock, casos GH/apoderados/condominio</span></div>
          <div class="est-hours" style="color:var(--moss)">6 hs</div>
        </div>
      </div>
      <div class="est-subtotal">
        <div class="est-sub-label">Subtotal Backend</div>
        <div class="est-sub-val" style="color:var(--moss)">42 hs</div>
      </div>
    </div>

    <!-- FRONTEND -->
    <div class="est-card">
      <div class="est-header">
        <div class="est-header-title">Frontend — React + Vite</div>
        <div class="est-header-color" style="background:#61dafb"></div>
      </div>
      <div class="est-rows">
        <div class="est-row">
          <div class="est-task">Setup, routing (React Router), estado global<span class="task-sub">Vite, Zustand/Context, axios, estructura de módulos</span></div>
          <div class="est-hours" style="color:#61dafb">4 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">Design system / algunos componentes base<span class="task-sub">Layout, estilos visuales, Input, Select, Button, Card, notificaciones</span></div>
          <div class="est-hours" style="color:#61dafb">8 hs</div>
        </div>
        <!-- <div class="est-row">
          <div class="est-task">FormDatosDelTramite + FormVehiculo<span class="task-sub">todos los campos de trgDatos + trgVehiculo</span></div>
          <div class="est-hours" style="color:#61dafb">8 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">FormTitulares — lista dinámica<span class="task-sub">agregar/quitar titulares, cónyuge condicional, validaciones</span></div>
          <div class="est-hours" style="color:#61dafb">10 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">FormApoderados + FormCedulasAzul + FormGuardaHabitual<span class="task-sub">arrays dinámicos, campos condicionales, tablas de códigos</span></div>
          <div class="est-hours" style="color:#61dafb">10 hs</div>
        </div> -->
        <div class="est-row">
          <div class="est-task">ExcelUpload — drag &amp; drop + previsualización<span class="task-sub">SheetJS, mapeo a secciones, detección de errores de columnas</span></div>
          <div class="est-hours" style="color:#61dafb">8 hs</div>
        </div>
        <div class="est-row">
          <div class="est-task">Dashboard — historial de trámites (PROPUESTA)<span class="task-sub">tabla paginada, estados, descarga F01 y F12</span></div>
